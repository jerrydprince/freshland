# .env.example (Frontend)

# Supabase API Configuration (Per Domain)
VITE_SUPABASE_URL=https://[YOUR_SUPABASE_PROJECT].supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]

# API Proxy Configuration
# Set this to the backend server URL (e.g. https://api.yourdomain.com/api or just /api if deployed on same host)
VITE_API_URL=/api

# Resend Mail Configuration (Optional if using cPanel SMTP on backend)
VITE_RESEND_API_KEY=

# SMS Gateway Configuration (Optional)
VITE_SMS_SENDER_ID=Sparkles
